{
  "private": true,
  "name": "shared-lib",
  "version": "0.1.0",
  "scripts": {
    "build": "nuxt build --dotenv ../../.env ./frontend/admin",
    "dev": "nuxt dev --dotenv ../../.env ./frontend/admin",
    "preview": "nuxt preview --dotenv ../../.env ./frontend/admin",
    "generate:admin-frontend": "nuxt generate --dotenv ../../.env ./frontend/admin",
    "generate:oauth": "vite build",
    "generate": "yarn generate:admin-frontend && yarn generate:oauth",
    "install-husky": "[ ! -d \"node_modules/husky/\" ] || husky",
    "postinstall": "yarn install-husky && nuxt prepare --dotenv ../../.env ./frontend/admin",
    "lint": "eslint ./frontend/admin",
    "lintfix": "eslint --fix ./frontend/admin",
    "tsc": "vue-tsc -p ./frontend/admin/tsconfig.json --noEmit --skipLibCheck",
    "test": "vitest ./frontend/admin --config ./frontend/admin/vitest.config.mts",
    "coverage": "yarn test --run --silent --coverage",
    "generate-icon-font": "npx fantasticon@1.2.x ./frontend/admin/assets/fonts/icons/raw -o ./frontend/admin/assets/fonts/icons --normalize",
    "generate-api-doc": "npx ts-node@10.9.x ./scripts/generate-api-doc.ts"
  },
  "dependencies": {
    "@casl/ability": "^6.5.0",
    "@casl/vue": "^2.2.1",
    "@mdi/font": "^7.1.96",
    "@nuxt/eslint": "^1.2.0",
    "@nuxt/test-utils": "^3.9.0",
    "@pinia/nuxt": "^0.11.0",
    "@types/lodash-es": "^4.17.10",
    "@types/node": "^22.13.10",
    "@vueuse/core": "^13.0.0",
    "@vueuse/integrations": "^13.0.0",
    "autoprefixer": "^10.4.21",
    "change-case": "^5.4.3",
    "cronstrue": "^2.56.0",
    "date-fns": "^4.1.0",
    "laravel-vite-plugin": "^1.2.0",
    "lodash-es": "^4.17.21",
    "nuxt": "^3.17.2",
    "nuxt-security": "^2.0.0",
    "pinia": "^3.0.1",
    "postcss": "^8.5.3",
    "sass-embedded": "^1.80.3",
    "tailwindcss": "3",
    "typescript": "^5.8.3",
    "vite": "^7.0.5",
    "vue-tsc": "^2.1.6",
    "vuetify": "^3.8.5",
    "vuetify-nuxt-module": "^0.18.3"
  },
  "devDependencies": {
    "@inquirer/prompts": "^7.0.1",
    "@nuxt/kit": "^4.0.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@testing-library/vue": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.0.2",
    "eslint": "^9.5.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "globals": "^16.0.0",
    "happy-dom": "^17.4.4",
    "husky": "^9.0.1",
    "lint-staged": "^16.0.0",
    "nuxt-proxy-request": "^2.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.2",
    "vitest-environment-nuxt": "^1.0.0",
    "vue": "^3.5.17"
  },
  "resolutions": {
    "unconfig": "^7.3.1"
  }
}
